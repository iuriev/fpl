{
  "name": "fpl",
  "version": "1.0.0",
  "description": "Fantasy Premier League squad viewer (mobile-first)",
  "private": true,
  "workspaces": [
    "web",
    "proxy"
  ],
  "scripts": {
    "predev": "lsof -ti :3000 -ti :3001 | xargs kill -9 2>/dev/null; true",
    "dev": "concurrently -n proxy,web -c blue,green \"npm run dev -w proxy\" \"npm run dev -w web\"",
    "build": "npm run --workspaces build",
    "lint": "npm run --workspaces lint",
    "format": "prettier --write \"**/*.{ts,tsx,json,css,md}\" --ignore-path .gitignore",
    "test": "npm run --workspaces test",
    "test:ui": "npm run --workspaces --if-present test:ui",
    "deploy": "fly deploy"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
