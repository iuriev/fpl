# Supabase Postgres connection string (direct connection, port 5432)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# better-auth secrets — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Google OAuth credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Public URL of this app (used by better-auth for OAuth redirects)
PUBLIC_APP_URL=http://localhost:3001

# Comma-separated list of trusted frontend origins (dev default: http://localhost:5173)
TRUSTED_ORIGINS=http://localhost:3000

# Resend email transport (https://resend.com)
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@yourdomain.com

# Dev only: grant premium tier to this email without DB change
# PREMIUM_OVERRIDE_EMAIL=you@example.com
