{
  "name": "fpl-proxy",
  "version": "1.0.0",
  "description": "FPL Proxy — Hono server fronting the public FPL API",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env --exclude 'src/data/**' src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest --run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "pred:ingest": "tsx --env-file=.env src/pred-cli.ts ingest",
    "pred:score": "tsx --env-file=.env src/pred-cli.ts score",
    "pred:verify": "tsx --env-file=.env src/pred-verify.ts",
    "lineups:warmup": "tsx --env-file=.env src/lineups-warmup-cli.ts",
    "lineups:ingest-tm": "tsx scripts/ingest-transfermarkt-positions.ts",
    "lineups:seed-positions": "npm run lineups:ingest-tm"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.3",
    "better-auth": "^1.6.13",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.21",
    "postgres": "^3.4.9",
    "resend": "^6.12.4",
    "tsx": "^4.22.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitest/coverage-v8": "^4.1.8",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  }
}
